---
import { siteConfig } from "../../config";
import { fetchImageUrls } from "../../utils/image-api";
import type { FullscreenWallpaperConfig } from "../../types/config";

interface Props {
	config: FullscreenWallpaperConfig;
	className?: string;
}

const { config, className } = Astro.props;

// 获取当前设备类型的图片源
const getImageSources = async () => {
	const srcConfig = config.src;

	// API 图片逻辑（含 alcy-api 备选）
	if (siteConfig.banner.imageApi?.enable) {
		const apiImages = await fetchImageUrls(siteConfig.banner.imageApi);
		if (apiImages.length > 0) {
			return { desktop: apiImages, mobile: apiImages };
		}
	}

	const toArray = (src: string | string[] | undefined): string[] => 
		Array.isArray(src) ? src : (typeof src === "string" ? [src] : []);

	if (typeof srcConfig === "object" && srcConfig !== null && !Array.isArray(srcConfig)) {
		const desktop = toArray(srcConfig.desktop);
		const mobile = toArray(srcConfig.mobile);
		return {
			desktop: desktop.length > 0 ? desktop : mobile,
			mobile: mobile.length > 0 ? mobile : desktop,
		};
	}

	// 如果是字符串或字符串数组，同时用于桌面端和移动端
	const allImages = toArray(srcConfig as string | string[]);
	return { desktop: allImages, mobile: allImages };
};

const imageSources = await getImageSources();
const hasDesktopImages = imageSources.desktop.length > 0;
const hasMobileImages = imageSources.mobile.length > 0;

if (!hasDesktopImages && !hasMobileImages) {return null;}

// 轮播配置
const isCarouselEnabled = config.carousel?.enable && 
	(imageSources.desktop.length > 1 || imageSources.mobile.length > 1);
const carouselInterval = config.carousel?.interval || 5;

// 样式配置
const position = config.position || "center";
const zIndex = config.zIndex || -1;
const opacity = config.opacity || 0.8;
const blurAmount = config.blur || 0;
const positionClass = (() => {
	switch (position) {
		case "top": return "object-top";
		case "bottom": return "object-bottom";
		default: return "object-center";
	}
})();

const renderGroups = [
	{
		key: 'desktop',
		images: imageSources.desktop,
		containerClass: "hidden md:block",
		hasImages: hasDesktopImages
	},
	{
		key: 'mobile',
		images: imageSources.mobile,
		containerClass: "block md:hidden",
		hasImages: hasMobileImages
	}
];
---

<div 
	class:list={[
		"fixed inset-0 w-full h-full overflow-hidden pointer-events-none",
		className
	]}
	style={`z-index: ${zIndex}; opacity: ${opacity}; transform: translateZ(0); perspective: 1000px;`}
	data-fullscreen-wallpaper
>
	<script is:inline>
	// 立即执行脚本：检测设备等级 + 防止闪烁
	(function() {
		const parent = document.currentScript.parentElement;
		const html = document.documentElement;
		const isLowTier = html.classList.contains('device-tier-low');
		const isMediumTier = html.classList.contains('device-tier-medium');

		// 低端设备：纯色背景，不加载任何图片/JSON
		if (isLowTier) {
			window.__deviceTier = 'low';
			parent.style.display = 'none';
			return;
		}

		const mode = localStorage.getItem('wallpaperMode') || 'banner';
		if (mode !== 'fullscreen') {
			parent.style.display = 'none';
			return;
		}

		// 中端设备：标记并禁用模糊效果
		if (isMediumTier) {
			const container = document.getElementById('wallpaper-single-container');
			if (container) {container.style.filter = 'none';}
			window.__deviceTier = 'medium';
		}
	})();
	</script>

	<!-- blur 移到父容器上避免轮播切换时因滤镜重算导致闪屏 -->
	<div id="wallpaper-single-container" class="w-full h-full relative" style={`transform: translateZ(0); ${blurAmount > 0 ? `filter: blur(${blurAmount}px);` : ''} backface-visibility: hidden;`}>
	{isCarouselEnabled ? (
		renderGroups.map(group => group.hasImages && (
			<div class={`${group.containerClass} w-full h-full relative`} style="transform: translateZ(0);">
				{group.images.map((src, index) => (
					<img
						src={src}
						alt={`${group.key} wallpaper ${index + 1}`}
						class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${positionClass}`}
						data-carousel-item={index}
						style={`transform: translateZ(0); backface-visibility: hidden; will-change: opacity; opacity: ${index === 0 ? 1 : 0};`}
						decoding="async"
						loading={index === 0 ? "eager" : "lazy"}
						fetchpriority={index === 0 ? "high" : undefined}
					/>
				))}
			</div>
		))
	) : (
		<script is:inline define:vars={{ desktopImages: imageSources.desktop, mobileImages: imageSources.mobile, positionClass, blurAmount }}>
			(function() {
				const getRandomImage = (images, storageKey) => {
					if (images.length === 0) {return null;}
					if (images.length === 1) {return images[0];}
					
					const lastIndex = sessionStorage.getItem(storageKey);
					let newIndex;
					
					do {
						newIndex = Math.floor(Math.random() * images.length);
					} while (newIndex === parseInt(lastIndex || '-1'));
					
					sessionStorage.setItem(storageKey, newIndex.toString());
					return images[newIndex];
				};
				
				const desktopSrc = getRandomImage(desktopImages, 'wallpaper_desktop_index');
				const mobileSrc = getRandomImage(mobileImages, 'wallpaper_mobile_index');
				
				const container = document.getElementById('wallpaper-single-container');
				
				if (desktopSrc) {
					const desktopDiv = document.createElement('div');
					desktopDiv.className = 'hidden lg:block w-full h-full relative';
					desktopDiv.style.transform = 'translateZ(0)';
					desktopDiv.innerHTML = `
						<img
							src="${desktopSrc}"
							alt="desktop wallpaper"
							class="absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${positionClass}"
							style="transform: translateZ(0); backface-visibility: hidden; will-change: opacity; opacity: 1;"
							decoding="async"
							loading="eager"
							fetchpriority="high"
						/>
					`;
					container.appendChild(desktopDiv);
				}
				
				if (mobileSrc) {
					const mobileDiv = document.createElement('div');
					mobileDiv.className = 'block lg:hidden w-full h-full relative';
					mobileDiv.style.transform = 'translateZ(0)';
					mobileDiv.innerHTML = `
						<img
							src="${mobileSrc}"
							alt="mobile wallpaper"
							class="absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${positionClass}"
							style="transform: translateZ(0); backface-visibility: hidden; will-change: opacity; opacity: 1;"
							decoding="async"
							loading="eager"
							fetchpriority="high"
						/>
					`;
					container.appendChild(mobileDiv);
				}
			})();
		</script>
	)}
	</div>
</div>

<!-- 设备等级降级清理脚本 -->
<script is:inline>
(function() {
	const tier = window.__deviceTier;
	if (!tier) return;

	// 低端设备：清除所有图片内容，设置纯色背景
	if (tier === 'low') {
		const parent = document.querySelector('[data-fullscreen-wallpaper]');
		if (parent) {
			parent.innerHTML = '';
			parent.style.background = 'var(--page-bg)';
			parent.style.display = 'block';
		}
		return;
	}

	// 中端设备：每组只保留第一张图片（禁用轮播）
	if (tier === 'medium') {
		// 处理 SSR 渲染的 carousel 图片
		document.querySelectorAll('[data-carousel-item]').forEach((img, idx) => {
			if (idx > 0) img.remove();
		});
		// 非轮播模式由随机脚本只生成一张图，无需额外处理
	}
})();
</script>

{isCarouselEnabled && (
	<script is:inline define:vars={{ carouselInterval }}>
		function initFullscreenWallpaperCarousel() {
			// 中端/低端设备跳过轮播（低端已在 cleanup 中清空，中端只有单张图）
			if (window.__deviceTier === 'medium' || window.__deviceTier === 'low') return;

			const container = document.querySelector('[data-fullscreen-wallpaper]');
			if (!container) {return;}

			if (window.__wallpaper_cleanup) {
				window.__wallpaper_cleanup();
				window.__wallpaper_cleanup = null;
			}

			const STORAGE_KEY = 'xinStar_wallpaper_index';
			const savedIndex = parseInt(sessionStorage.getItem(STORAGE_KEY) || '0');

			const groups = [
				container.querySelectorAll('.hidden.md\\:block [data-carousel-item]'),
				container.querySelectorAll('.block.md\\:hidden [data-carousel-item]')
			];

			const state = groups.map(items => {
				const safeIndex = (savedIndex >= 0 && savedIndex < items.length) ? savedIndex : 0;
				return {
					items,
					currentIndex: safeIndex,
					timer: null,
					active: items.length > 1
				};
			});

			function initImage(stateItem) {
				const { items, currentIndex } = stateItem;
				for (let i = 0; i < items.length; i++) {
					items[i].style.opacity = i === currentIndex ? '1' : '0';
				}
			}

			function switchNextImage(stateItem) {
				const { items, currentIndex } = stateItem;
				const nextIndex = (currentIndex + 1) % items.length;

				items[currentIndex].style.opacity = '0';
				items[nextIndex].style.opacity = '1';

				stateItem.currentIndex = nextIndex;
				sessionStorage.setItem(STORAGE_KEY, nextIndex.toString());
			}

			function start() {
				state.forEach(s => {
					if (s.active && !s.timer) {
						s.timer = setInterval(() => {
							if (!document.body.contains(s.items[0])) {
								stop();
								return;
							}
							switchNextImage(s);
						}, carouselInterval * 1000);
					}
				});
			}

			function stop() {
				state.forEach(s => {
					if (s.timer) {
						clearInterval(s.timer);
						s.timer = null;
					}
				});
			}

			const handleVisibilityChange = () => {
				if (document.hidden) {
					stop();
				} else {
					const exists = state.some(s => s.items.length > 0 && document.body.contains(s.items[0]));
					if (exists) {start();}
				}
			};

			state.forEach(s => {
				if (s.items.length > 0) {initImage(s);}
			});

			start();
			document.addEventListener('visibilitychange', handleVisibilityChange);

			window.__wallpaper_cleanup = () => {
				stop();
				document.removeEventListener('visibilitychange', handleVisibilityChange);
			};

			// 暴露给外部脚本（如 wallpaper source 切换）以便重新初始化轮播
			window.__initWallpaperCarousel = initFullscreenWallpaperCarousel;
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initFullscreenWallpaperCarousel);
		} else {
			initFullscreenWallpaperCarousel();
		}
	</script>
)}

{/* 壁纸来源动态切换脚本 */}
<script is:inline define:vars={{ positionClass, blurAmount, zIndex, opacity }}>
(function() {
	'use strict';

	// 低端/中端设备：跳过壁纸来源动态切换，不请求 JSON
	const tier = window.__deviceTier;
	if (tier === 'low' || tier === 'medium') return;

	/**
	 * Read wallpaper data from the pre-built static JSON.
	 */
	let wallpaperData = null;

	async function loadWallpaperData() {
		if (wallpaperData) return wallpaperData;
		try {
			const res = await fetch('/data/wallpapers.json');
			if (!res.ok) return null;
			wallpaperData = await res.json();
			return wallpaperData;
		} catch {
			return null;
		}
	}

	/**
	 * Get wallpaper URLs for a specific source.
	 */
	async function getWallpaperUrls(sourceId) {
		const data = await loadWallpaperData();
		if (!data) return null;
		const items = data[sourceId];
		if (!items || items.length === 0) return null;
		return items.map(i => i.url || i);
	}

	/**
	 * Replace all wallpaper images with new URLs.
	 * 支持多图轮播：当 urls.length > 1 时创建 carousel-item 并启动轮播
	 * blur 由父容器 #wallpaper-single-container 统一处理，img 不再单独设置 filter
	 */
	function replaceWallpaperImages(urls) {
		if (!urls || urls.length === 0) return;

		const container = document.getElementById('wallpaper-single-container');
		if (!container) return;

		const makeCarouselImg = (src, index, label) => {
			const img = document.createElement('img');
			img.src = src;
			img.alt = label + ' wallpaper ' + (index + 1);
			img.className = 'absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ' + positionClass;
			img.style.cssText = 'transform: translateZ(0); backface-visibility: hidden; will-change: opacity; opacity: ' + (index === 0 ? 1 : 0) + ';';
			img.setAttribute('data-carousel-item', index.toString());
			img.decoding = 'async';
			img.loading = index === 0 ? 'eager' : 'lazy';
			img.fetchPriority = index === 0 ? 'high' : 'auto';
			return img;
		};

		const desktopDiv = document.createElement('div');
		desktopDiv.className = 'hidden lg:block w-full h-full relative';
		desktopDiv.style.transform = 'translateZ(0)';
		urls.forEach((url, i) => {
			desktopDiv.appendChild(makeCarouselImg(url, i, 'desktop'));
		});

		const mobileDiv = document.createElement('div');
		mobileDiv.className = 'block lg:hidden w-full h-full relative';
		mobileDiv.style.transform = 'translateZ(0)';
		urls.forEach((url, i) => {
			mobileDiv.appendChild(makeCarouselImg(url, i, 'mobile'));
		});

		container.innerHTML = '';
		container.appendChild(desktopDiv);
		container.appendChild(mobileDiv);

		// 重新初始化轮播以拾取新创建的 carousel-item
		if (typeof window.__initWallpaperCarousel === 'function') {
			window.__initWallpaperCarousel();
		}
	}

	// On load: check if user has a non-default source
	const savedSource = localStorage.getItem('wallpaperSource');
	const sources = window.siteConfig?.wallpaperMode?.availableSources;
	if (savedSource && savedSource !== 'default' && sources && sources.length > 1) {
		getWallpaperUrls(savedSource).then(urls => {
			if (urls) replaceWallpaperImages(urls);
		});
	}

	// Listen for source change events
	window.addEventListener('wallpaper-source-change', (e) => {
		const source = e.detail?.source;
		if (source && source !== 'default') {
			getWallpaperUrls(source).then(urls => {
				if (urls) replaceWallpaperImages(urls);
			});
		} else if (source === 'default') {
			// Reload the page to use the default static wallpapers
			window.location.reload();
		}
	});

	window.addEventListener('wallpaper-refetch', (e) => {
		const source = e.detail?.source || localStorage.getItem('wallpaperSource') || 't-alcy-cc';
		if (source !== 'default') {
			getWallpaperUrls(source).then(urls => {
				if (urls) replaceWallpaperImages(urls);
			});
		}
	});
})();
</script>

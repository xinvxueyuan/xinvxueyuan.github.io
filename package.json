{
	"name": "xinvxueyuan-blog",
	"type": "module",
	"version": "1.0",
	"engines": {
		"node": ">=22.12.0",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint next.config.ts playwright.config.ts vitest.config.ts \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.mts\" --max-warnings 0",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"framework:scan": "node scripts/verify-mvp.mts",
		"verify": "pnpm framework:scan && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
		"format": "prettier --write src tests scripts *.ts *.mjs"
	},
	"dependencies": {
		"@shikijs/rehype": "4.3.1",
		"github-slugger": "2.0.0",
		"gray-matter": "^4.0.3",
		"next": "16.2.10",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"rehype-slug": "6.0.0",
		"rehype-stringify": "10.0.1",
		"remark-gfm": "4.0.1",
		"remark-parse": "11.0.0",
		"remark-rehype": "11.1.2",
		"unified": "11.0.5",
		"unist-util-visit": "^5.1.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@playwright/test": "1.61.1",
		"@tailwindcss/postcss": "4.3.2",
		"@types/hast": "^3.0.4",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"eslint": "^9.39.2",
		"eslint-config-next": "16.2.10",
		"prettier": "^3.9.4",
		"tailwindcss": "4.3.2",
		"typescript": "6.0.3",
		"vitest": "4.1.10"
	},
	"packageManager": "pnpm@10.22.0",
	"pnpm": {
		"overrides": {
			"@emmetio/css-parser": "https://codeload.github.com/ramya-rao-a/css-parser/tar.gz/370c480ac103bd17c7bcfb34bf5d577dc40d3660",
			"tar": "^7.5.19",
			"fast-xml-parser": "^5.9.0",
			"uuid": "^14.0.0",
			"tmp": "^0.2.7",
			"serialize-javascript": "^7.0.7",
			"esbuild": "^0.28.1"
		}
	}
}

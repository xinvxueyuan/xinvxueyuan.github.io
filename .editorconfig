root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,json,jsonc}]
indent_style = tab
indent_size = 4

[*.{md,mdx,yml,yaml,toml}]
indent_style = space
indent_size = 4

[*.{css,scss}]
indent_style = space
indent_size = 2

[*.{png,jpg,jpeg,gif,webp,avif,ico,woff,woff2,ttf}]
insert_final_newline = unset
trim_trailing_whitespace = unset

[Makefile]
indent_style = tab
